<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="14" xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.tuiperacer.view.OnlineLobbyController"
      minWidth="600" minHeight="500">

    <padding>
        <Insets top="20" right="24" bottom="20" left="24"/>
    </padding>

    <Label fx:id="titleLabel" text="Lobby Online" styleClass="title-label" style="-fx-font-size: 22;"/>
    <Label fx:id="statusLabel" text="Aguardando..." styleClass="subtitle-label"/>

    <!-- HOST MODE panel -->
    <VBox fx:id="hostPanel" spacing="10" VBox.vgrow="ALWAYS"
          style="-fx-background-color: #181825; -fx-padding: 12; -fx-background-radius: 6;">
        <Label text="Hospedar Corrida" style="-fx-font-weight: bold; -fx-text-fill: #89b4fa;"/>
        <HBox spacing="8" alignment="CENTER_LEFT">
            <Label text="Seu nome:" minWidth="80" style="-fx-text-fill: #cdd6f4;"/>
            <TextField fx:id="hostNameField" promptText="Digite seu nome" HBox.hgrow="ALWAYS"/>
        </HBox>
        <Label fx:id="hostInfoLabel" text="Iniciando servidor..." style="-fx-text-fill: #a6e3a1;"/>
        <Label fx:id="playerCountLabel" text="Jogadores conectados: 0" style="-fx-text-fill: #cdd6f4;"/>
        <Label text="Jogadores na sala:" style="-fx-text-fill: #a6adc8; -fx-font-weight: bold;"/>
        <ListView fx:id="lobbyListView" VBox.vgrow="ALWAYS" styleClass="list-view" prefHeight="140"/>
        <Button text="Iniciar Corrida" onAction="#onStartRace" prefWidth="180"
                style="-fx-background-color: #a6e3a1; -fx-text-fill: #1e1e2e; -fx-font-weight: bold;"/>
    </VBox>

    <!-- JOIN MODE panel (connect form) -->
    <VBox fx:id="joinPanel" spacing="10"
          style="-fx-background-color: #181825; -fx-padding: 12; -fx-background-radius: 6;">
        <Label text="Conectar a servidor" style="-fx-font-weight: bold; -fx-text-fill: #89b4fa;"/>
        <HBox spacing="8" alignment="CENTER_LEFT">
            <Label text="Host:" minWidth="60" style="-fx-text-fill: #cdd6f4;"/>
            <TextField fx:id="joinHostField" promptText="192.168.1.100" HBox.hgrow="ALWAYS"/>
        </HBox>
        <HBox spacing="8" alignment="CENTER_LEFT">
            <Label text="Porta:" minWidth="60" style="-fx-text-fill: #cdd6f4;"/>
            <TextField fx:id="joinPortField" promptText="3000" prefWidth="100"/>
        </HBox>
        <HBox spacing="8" alignment="CENTER_LEFT">
            <Label text="Seu nome:" minWidth="60" style="-fx-text-fill: #cdd6f4;"/>
            <TextField fx:id="joinNameField" promptText="Digite seu nome" HBox.hgrow="ALWAYS"/>
        </HBox>
        <Button text="Entrar" onAction="#onJoin" prefWidth="180"
                style="-fx-background-color: #89b4fa; -fx-text-fill: #1e1e2e; -fx-font-weight: bold;"/>
    </VBox>

    <!-- JOIN waiting panel (shown after connecting) -->
    <VBox fx:id="waitingPanel" spacing="10" VBox.vgrow="ALWAYS"
          style="-fx-background-color: #181825; -fx-padding: 12; -fx-background-radius: 6;"
          visible="false" managed="false">
        <Label text="Aguardando o host iniciar a corrida..."
               style="-fx-text-fill: #f9e2af; -fx-font-weight: bold; -fx-font-size: 14;"/>
        <Label text="Jogadores na sala:" style="-fx-text-fill: #a6adc8; -fx-font-weight: bold;"/>
        <ListView fx:id="waitingPlayerListView" VBox.vgrow="ALWAYS" styleClass="list-view" prefHeight="140"/>
    </VBox>

    <!-- Back button -->
    <HBox alignment="CENTER_LEFT">
        <Button text="&#8592; Voltar" onAction="#onBack" styleClass="button"/>
    </HBox>

</VBox>
