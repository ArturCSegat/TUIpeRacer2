<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.tuiperacer.view.RaceController"
            minWidth="800" minHeight="500">

    <!-- TOP: title and timer -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20"
              style="-fx-padding: 10 16 10 16; -fx-background-color: #181825;">
            <Label text="TUIpeRacer 2" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #89b4fa;"/>
            <HBox HBox.hgrow="ALWAYS"/>
            <Label text="Tempo: " style="-fx-text-fill: #a6adc8;"/>
            <Label fx:id="timerLabel" text="00:00"
                   style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #cdd6f4;"/>
        </HBox>
    </top>

    <!-- CENTER: scrollable player panels (built dynamically) -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane"
                    style="-fx-background-color: #1e1e2e;">
            <VBox fx:id="playersContainer" spacing="16">
                <padding>
                    <Insets top="16" right="16" bottom="16" left="16"/>
                </padding>
            </VBox>
        </ScrollPane>
    </center>

    <!-- BOTTOM: give up button -->
    <bottom>
        <HBox alignment="CENTER" spacing="16"
              style="-fx-padding: 10; -fx-background-color: #181825;">
            <Button text="Desistir" onAction="#onGiveUp"
                    style="-fx-background-color: #f38ba8; -fx-text-fill: #1e1e2e; -fx-font-weight: bold;"/>
        </HBox>
    </bottom>

</BorderPane>
