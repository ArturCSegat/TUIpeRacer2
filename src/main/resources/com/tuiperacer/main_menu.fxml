<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.tuiperacer.view.MainMenuController">

    <padding>
        <Insets top="60" right="40" bottom="60" left="40"/>
    </padding>

    <Label text="TUIpeRacer 2" styleClass="title-label"/>
    <Label text="Um jogo de corrida de digitação" styleClass="subtitle-label"/>

    <VBox spacing="12" alignment="CENTER" style="-fx-padding: 30 0 0 0;">
        <Button text="Corrida Local"
                prefWidth="220"
                onAction="#onLocalRace"
                styleClass="button"/>
<Button text="Hospedar Corrida Online"
                prefWidth="220"
                onAction="#onHostOnline"
                styleClass="button"/>
        <Button text="Entrar em Corrida Online"
                prefWidth="220"
                onAction="#onJoinOnline"
                styleClass="button"/>
        <Button text="Resultados"
                prefWidth="220"
                onAction="#onResults"
                styleClass="button"/>
        <Button text="Sair"
                prefWidth="220"
                onAction="#onExit"
                styleClass="button"/>
    </VBox>
</VBox>
